PORT=3000
NODE_ENV=development

# JWT 시크릿 키
JWT_ACCESS_SECRET=your_access_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production

# JWT 만료 시간
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=1209600

# MongoDB
MONGODB_USER=your_mongo_username
MONGODB_PASSWORD=your_mongo_password
MONGODB_URI=mongodb://your_mongo_username:your_mongo_password@mongodb:27017/taskrit?authSource=admin

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_LOCK_TIME=600000
RATE_LIMIT_MAX_STORE_SIZE=50000

# Solana
SOLANA_CLUSTER=devnet
HMAC_KEY=your_hmac_key_here_change_in_production

# Teaming
TEAMING_API_BASE=http://localhost:3002

# Settlement Token / Master Wallet
MASTER_WALLET_SECRET=your_phantom_private_key_here
TASK_TOKEN_MINT=your_task_token_mint_address_here
SETTLEMENT_DEFAULT_AMOUNT=100
SETTLEMENT_TASK_PRICE_KRW=1325
SETTLEMENT_MIN_TASK=0.01
# Optional cap. Set to 0 to disable cap.
SETTLEMENT_MAX_TASK=0
